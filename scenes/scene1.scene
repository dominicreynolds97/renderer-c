// SCENE 1

mesh plane meshes/plane.obj
mesh cube meshes/cube.obj
mesh cylinder meshes/cylinder.obj

// Skybox
skybox
  color 0.53 0.81 0.98
end

// Materials
material red
  color 1.0 0.2 0.2
end

material teal
  color 0.4 0.8 0.8
end

material green
  color 0.4 0.8 0.4
end

// Objects
object plane green
  scale 30.0 1.0 30.0
  position 0.0 0.0 0.0
  collider
    extents 15.0 0.1 15.0
  end
end

object cube red
  position -2.0 1.0 0.0
  collider
    extents 1.0 1.0 1.0
  end
  speed 1.0
  path loop
    waypoint 0.0 0.0 0.0
    waypoint 5.0 0.0 0.0
    waypoint 5.0 0.0 5.0
    waypoint 0.0 0.0 5.0
  end
end

object cylinder teal
  position 2.0 1.0 -2.0
  collider
    extents 1.0 1.0 1.0
  end
  speed 2.0
  path loop
    waypoint 0.0 0.0 0.0
    waypoint 0.0 10.0 0.0
  end
end
