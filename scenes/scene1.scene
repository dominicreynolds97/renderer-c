// SCENE 1

mesh plane meshes/plane.obj
mesh cube meshes/cube.obj
mesh sphere meshes/sphere.obj
mesh cylinder meshes/cylinder.obj

// Skybox
skybox
  color 0.53 0.81 0.98
end

// Materials
material red
  color 1.0 0.2 0.2
end

material teal
  color 0.4 0.8 0.8
end

material green
  color 0.4 0.8 0.4
end

// Objects
object plane green
  scale 30.0 1.0 30.0
  position 0.0 0.0 0.0
  collider
    extents 15.0 0.1 15.0
    friction 0.8
  end
end

object cube red
  position -2.0 1.0 0.0
  mass 150.0
  collider dynamic
    extents 1.0 1.0 1.0
  end
end

object cylinder teal
  position 2.0 10.0 -2.0
  mass 200.0
  collider dynamic
    extents 1.0 1.0 1.0
  end
end

object sphere red
  position 5.0 20.0 0.0
  scale 0.5 0.5 0.5
  velocity 0.0 0.0 -1.0
  mass 25.0
  collider dynamic
    extents 0.5 0.5 0.5
    restiution 0.8
    friction 0.7
  end
end
